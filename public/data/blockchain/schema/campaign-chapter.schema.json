{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rushpi.local/schema/campaign-chapter.schema.json",
  "title": "Rush Pi Campaign chapter candidates",
  "type": "object",
  "required": ["schemaVersion", "lastReviewedAt", "seasonOne", "chapters"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "lastReviewedAt": { "type": "string", "format": "date" },
    "seasonOne": { "type": "object" },
    "chapters": {
      "type": "array",
      "minItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "seasonOneRecommended", "seasonOrder", "title", "chainOrFamily", "technologyType", "gameplayTemplate", "conceptLearned", "gameplayFantasy", "playerActions", "winCondition", "failConditions", "difficulty", "durationTarget", "educationalMessage", "briefing", "midLevelEvolution", "finalSequence", "assetsNeeded", "animationsNeeded", "officialSources", "simplificationNotes", "accuracyStatus", "lastReviewedAt", "editorialReview"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "seasonOneRecommended": { "type": "boolean" },
          "seasonOrder": { "type": ["integer", "null"], "minimum": 1, "maximum": 8 },
          "title": { "type": "string" },
          "chainOrFamily": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "technologyType": { "type": "string" },
          "gameplayTemplate": { "enum": ["Runner Mission", "Hybrid Runner / Relay Mission", "Hybrid Runner / Routing / Validation", "Chain Maze", "Network Routing", "Validation Challenge", "Resource Puzzle", "Sequence/Atomic Mission"] },
          "conceptLearned": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "gameplayFantasy": { "type": "string" },
          "playerActions": { "type": "array", "minItems": 3, "items": { "type": "string" } },
          "winCondition": { "type": "string", "minLength": 15 },
          "failConditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "difficulty": { "enum": ["introductory", "intermediate", "advanced"] },
          "durationTarget": { "type": "integer", "minimum": 90, "maximum": 900 },
          "educationalMessage": { "type": "string" },
          "briefing": { "type": "string", "maxLength": 240 },
          "midLevelEvolution": { "type": "string" },
          "finalSequence": { "type": "string" },
          "assetsNeeded": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "animationsNeeded": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "officialSources": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "simplificationNotes": { "type": "string" },
          "contentWarning": {
            "type": "object",
            "required": ["en", "fr"],
            "properties": {
              "en": { "type": "string", "minLength": 20 },
              "fr": { "type": "string", "minLength": 20 }
            },
            "additionalProperties": false
          },
          "accuracyStatus": { "enum": ["current-official", "historical-official", "proposed-design", "simplified-for-game", "needs-verification"] },
          "lastReviewedAt": { "type": "string", "format": "date" },
          "editorialReview": {
            "type": "object",
            "required": ["status", "reviewedBy", "contentVerifiedAt", "reviewNotes", "releaseApproved"],
            "properties": {
              "status": { "enum": ["research-draft", "human-reviewed", "release-approved"] },
              "reviewedBy": { "type": ["string", "null"] },
              "contentVerifiedAt": { "type": ["string", "null"], "format": "date" },
              "reviewNotes": { "type": "array", "items": { "type": "string" } },
              "releaseApproved": { "type": "boolean" }
            },
            "allOf": [
              { "if": { "properties": { "status": { "const": "release-approved" } } }, "then": { "properties": { "reviewedBy": { "type": "string", "minLength": 1 }, "contentVerifiedAt": { "type": "string", "format": "date" }, "reviewNotes": { "minItems": 1 }, "releaseApproved": { "const": true } } } },
              { "if": { "properties": { "status": { "enum": ["research-draft", "human-reviewed"] } } }, "then": { "properties": { "releaseApproved": { "const": false } } } }
            ],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  }
}
