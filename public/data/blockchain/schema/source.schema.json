{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rushpi.local/schema/source.schema.json",
  "title": "Rush Pi blockchain source catalog",
  "type": "object",
  "required": ["schemaVersion", "lastReviewedAt", "sources"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "lastReviewedAt": { "type": "string", "format": "date" },
    "policy": { "type": "string", "minLength": 20 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "org", "url", "sourceType", "official", "accessedAt", "lastReviewedAt", "relevantTopics", "notes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "title": { "type": "string", "minLength": 3 },
          "org": { "type": "string", "minLength": 2 },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "sourceType": { "type": "string", "minLength": 3 },
          "official": { "const": true },
          "accessedAt": { "type": "string", "format": "date" },
          "lastReviewedAt": { "type": "string", "format": "date" },
          "relevantTopics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "notes": { "type": "string", "minLength": 10 }
        },
        "additionalProperties": false
      }
    }
  }
}
