{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rushpi.local/schema/chain-family.schema.json",
  "title": "Rush Pi chain and family profiles",
  "type": "object",
  "required": ["schemaVersion", "lastReviewedAt", "families"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "lastReviewedAt": { "type": "string", "format": "date" },
    "families": {
      "type": "array",
      "minItems": 22,
      "items": {
        "type": "object",
        "required": ["id", "displayName", "classification", "nativeArchitecture", "consensusModel", "transactionModel", "executionModel", "finalityModel", "feeModel", "interoperabilityModel", "privacyModel", "gameplayOpportunities", "unsuitableSimplifications", "officialSources", "sourceType", "lastReviewedAt", "accuracyStatus", "simplificationLevel", "simplificationNotes", "unresolvedQuestions"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "displayName": { "type": "string" },
          "classification": { "type": "string" },
          "nativeArchitecture": { "type": "string", "minLength": 15 },
          "consensusModel": { "type": "string", "minLength": 8 },
          "transactionModel": { "type": "string", "minLength": 8 },
          "executionModel": { "type": "string", "minLength": 8 },
          "finalityModel": { "type": "string", "minLength": 8 },
          "feeModel": { "type": "string", "minLength": 5 },
          "interoperabilityModel": { "type": "string", "minLength": 5 },
          "privacyModel": { "type": "string", "minLength": 5 },
          "gameplayOpportunities": { "$ref": "#/$defs/stringList" },
          "unsuitableSimplifications": { "$ref": "#/$defs/stringList" },
          "officialSources": { "$ref": "#/$defs/stringList" },
          "sourceType": { "$ref": "#/$defs/stringList" },
          "lastReviewedAt": { "type": "string", "format": "date" },
          "accuracyStatus": { "enum": ["current-official", "historical-official", "proposed-design", "simplified-for-game", "needs-verification"] },
          "simplificationLevel": { "enum": ["none", "low", "moderate", "high"] },
          "simplificationNotes": { "type": "string" },
          "unresolvedQuestions": { "type": "array", "items": { "type": "string" } },
          "statusLayers": { "type": "array", "items": { "type": "object", "required": ["claim", "status", "sourceIds"], "properties": { "claim": { "type": "string" }, "status": { "enum": ["current-official", "historical-official", "proposed-design", "simplified-for-game", "needs-verification"] }, "sourceIds": { "$ref": "#/$defs/stringList" } } } }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": { "stringList": { "type": "array", "minItems": 1, "items": { "type": "string" } } }
}
