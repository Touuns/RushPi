{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rushpi.local/schema/chain-maze-level.schema.json",
  "title": "Rush Pi Chain Maze levels",
  "type": "object",
  "required": ["schemaVersion", "lastReviewedAt", "tileTaxonomy", "levels"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "lastReviewedAt": { "type": "string", "format": "date" },
    "tileTaxonomy": { "type": "array", "minItems": 18, "items": { "type": "object", "required": ["type", "walkable", "stopsMovement", "meaning"], "properties": { "type": { "type": "string" }, "walkable": { "type": "boolean" }, "stopsMovement": { "type": "boolean" }, "meaning": { "type": "string" } }, "additionalProperties": false } },
    "levels": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "title", "chapterId", "width", "height", "start", "exit", "tiles", "rules", "resources", "objectives", "validationScenarios", "parMoves", "educationalConcept", "winCondition", "failConditions", "officialSources", "simplificationNotes", "accuracyStatus", "lastReviewedAt", "editorialReview"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "title": { "type": "string" },
          "chapterId": { "type": "string" },
          "width": { "type": "integer", "minimum": 3, "maximum": 30 },
          "height": { "type": "integer", "minimum": 3, "maximum": 30 },
          "start": { "$ref": "#/$defs/position" },
          "exit": { "$ref": "#/$defs/position" },
          "tiles": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/tile" } },
          "rules": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/rule" } },
          "resources": { "type": "array", "items": { "$ref": "#/$defs/resource" } },
          "objectives": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/objective" } },
          "validationScenarios": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/scenario" } },
          "parMoves": { "type": "integer", "minimum": 1 },
          "educationalConcept": { "type": "string" },
          "winCondition": { "type": "string" },
          "failConditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "officialSources": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "simplificationNotes": { "type": "string" },
          "accuracyStatus": { "enum": ["current-official", "historical-official", "proposed-design", "simplified-for-game", "needs-verification"] },
          "lastReviewedAt": { "type": "string", "format": "date" },
          "editorialReview": {
            "type": "object",
            "required": ["status", "reviewedBy", "contentVerifiedAt", "reviewNotes", "releaseApproved"],
            "properties": {
              "status": { "enum": ["research-draft", "human-reviewed", "release-approved"] },
              "reviewedBy": { "type": ["string", "null"] },
              "contentVerifiedAt": { "type": ["string", "null"], "format": "date" },
              "reviewNotes": { "type": "array", "items": { "type": "string" } },
              "releaseApproved": { "type": "boolean" }
            },
            "allOf": [
              { "if": { "properties": { "status": { "const": "release-approved" } } }, "then": { "properties": { "reviewedBy": { "type": "string", "minLength": 1 }, "contentVerifiedAt": { "type": "string", "format": "date" }, "reviewNotes": { "minItems": 1 }, "releaseApproved": { "const": true } } } },
              { "if": { "properties": { "status": { "enum": ["research-draft", "human-reviewed"] } } }, "then": { "properties": { "releaseApproved": { "const": false } } } }
            ],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "position": { "type": "object", "required": ["x", "y"], "properties": { "x": { "type": "integer", "minimum": 0 }, "y": { "type": "integer", "minimum": 0 } }, "additionalProperties": false },
    "tile": { "type": "object", "required": ["id", "x", "y", "type"], "properties": { "id": { "type": "string" }, "x": { "type": "integer", "minimum": 0 }, "y": { "type": "integer", "minimum": 0 }, "type": { "type": "string" }, "value": { "type": "integer" }, "cost": { "type": "integer" }, "targetId": { "type": "string" }, "direction": { "enum": ["up", "right", "down", "left"] }, "state": { "type": "string" }, "required": { "type": "boolean" } }, "additionalProperties": false },
    "rule": { "type": "object", "required": ["id", "type", "description"], "properties": { "id": { "type": "string" }, "type": { "type": "string" }, "description": { "type": "string" }, "parameters": { "type": "object" } }, "additionalProperties": false },
    "resource": { "type": "object", "required": ["id", "displayName", "initial", "minimum"], "properties": { "id": { "type": "string" }, "displayName": { "type": "string" }, "initial": { "type": "integer", "minimum": 0 }, "minimum": { "type": "integer", "minimum": 0 }, "target": { "type": "integer", "minimum": 0 } }, "additionalProperties": false },
    "objective": { "type": "object", "required": ["id", "type", "description"], "properties": { "id": { "type": "string" }, "type": { "type": "string" }, "resourceId": { "type": "string" }, "description": { "type": "string" }, "target": { "type": ["integer", "string", "array"] } }, "additionalProperties": false },
    "scenario": {
      "type": "object",
      "required": ["id", "label", "routeRole", "commands", "expectedStatus", "expectedFailureCode", "expectedMoves", "expectedResources"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "routeRole": { "enum": ["optimal", "alternate", "insufficient", "spent-output", "short-costly", "long-efficient", "out-of-gas", "revert", "premature-exit"] },
        "commands": { "type": "array", "minItems": 1, "items": { "enum": ["up", "right", "down", "left"] } },
        "expectedStatus": { "enum": ["won", "failed"] },
        "expectedFailureCode": { "type": ["string", "null"] },
        "expectedMoves": { "type": "integer", "minimum": 1 },
        "expectedResources": { "type": "object", "additionalProperties": { "type": "integer" } }
      },
      "additionalProperties": false
    }
  }
}
