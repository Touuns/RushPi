{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rushpi.local/schema/chain-maze-level.schema.json",
  "title": "Rush Pi Chain Maze levels",
  "type": "object",
  "required": ["schemaVersion", "lastReviewedAt", "tileTaxonomy", "levels"],
  "properties": { "schemaVersion": { "type": "string" }, "lastReviewedAt": { "type": "string", "format": "date" }, "tileTaxonomy": { "type": "object", "additionalProperties": { "type": "object", "required": ["walkable", "meaning"], "properties": { "walkable": { "type": "boolean" }, "meaning": { "type": "string" } } } }, "levels": { "type": "array", "minItems": 2, "items": { "type": "object", "required": ["id", "title", "chainFamilyIds", "primitiveIds", "width", "height", "grid", "start", "goal", "rules", "winCondition", "failureConditions", "explanation", "officialSources", "accuracyStatus", "lastReviewedAt"], "properties": { "id": { "type": "string" }, "title": { "type": "string" }, "chainFamilyIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "primitiveIds": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "width": { "type": "integer", "minimum": 3 }, "height": { "type": "integer", "minimum": 3 }, "grid": { "type": "array", "minItems": 3, "items": { "type": "string" } }, "start": { "$ref": "#/$defs/point" }, "goal": { "$ref": "#/$defs/point" }, "rules": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "winCondition": { "type": "string" }, "failureConditions": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "explanation": { "type": "string" }, "officialSources": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "accuracyStatus": { "type": "string" }, "lastReviewedAt": { "type": "string", "format": "date" } } } } },
  "$defs": { "point": { "type": "object", "required": ["x", "y"], "properties": { "x": { "type": "integer", "minimum": 0 }, "y": { "type": "integer", "minimum": 0 } } } }
}
