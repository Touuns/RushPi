{
  "name": "rush-pi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Rush Pi - A fast daily runner challenge for Pioneers (MVP, Phase 1)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "registry:build": "node tools/registry/build-v1.mjs",
    "registry:validate": "node tools/registry/validate.mjs",
    "registry:parity": "node tools/registry/parity.mjs",
    "registry:selftest": "node tools/registry/selftest.mjs",
    "registry:v2:build": "node tools/registry/build-v2.mjs",
    "registry:v2:validate": "node tools/registry/validate-v2.mjs",
    "registry:v2:selftest": "node tools/registry/selftest-v2.mjs",
    "logos:validate-plan": "node tools/logos/validate-source-plan.mjs",
    "logos:inspect": "node tools/logos/inspect-source.mjs",
    "logos:normalize": "node tools/logos/normalize-source.mjs",
    "logos:verify": "node tools/logos/verify-outputs.mjs",
