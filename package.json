    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "2.6.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^3.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "sharp": "0.35.3",
