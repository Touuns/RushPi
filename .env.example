# Rush Pi — environment variables
#
# Copy to .env.local for local dev (with `vercel dev`). NEVER commit real secrets.
# .env files are gitignored except this example.

# SERVER-ONLY secret. Set this in the Vercel Dashboard (not in the repo).
# Found in the Pi Developer Portal: your app -> API Key.
# Used by the /api/pi/* serverless functions to approve/complete payments.
PI_API_KEY=

# FRONTEND flag (optional). Set to "true" ONLY when running in the standalone
# Pi Sandbox web environment. Inside Pi Browser, leave it empty/false — the
# Testnet/Mainnet network is decided by the app config in the Pi Developer Portal.
VITE_PI_SANDBOX=

# SERVER-ONLY (Supabase leaderboard). Set these in the Vercel Dashboard.
# SUPABASE_URL: your project URL, e.g. https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: Supabase -> Project Settings -> API -> service_role
#   key. It bypasses RLS and MUST stay server-side only. Never expose it to the
#   frontend and never commit it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SERVER-ONLY (market data, Phase 11A). CoinGecko Demo API key:
# 1. create a free Demo key at https://www.coingecko.com/en/developers/dashboard
# 2. put it here in .env.local for local `vercel dev`
# 3. add it in Vercel -> Settings -> Environment Variables (Production+Preview)
# 4. NEVER prefix with VITE_ (that would ship it to the browser)
# 5. redeploy Vercel after adding it
# Without a key, the endpoints fall back to CoinGecko's public rate limits and
# to the built-in fallback/stale data when unavailable.
COINGECKO_DEMO_API_KEY=
